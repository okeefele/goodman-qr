<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0d0d12">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">
        <TextView android:id="@+id/resultText" android:layout_width="match_parent"
            android:layout_height="0dp" android:layout_weight="1"
            android:textColor="#00e5a0" android:textSize="15sp"
            android:gravity="center_vertical" android:textIsSelectable="true"
            android:hint="Наведите камеру на QR-код" android:textColorHint="#8a8a9a"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/copyBtn" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Копировать" android:enabled="false"/>
            <Button android:id="@+id/againBtn" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Ещё раз" android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
