<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:padding="24dp" android:background="#0d0d12">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="GoodMan QR" android:textColor="#ffffff" android:textSize="22sp"
        android:textStyle="bold" android:layout_marginBottom="20dp"/>
    <Button android:id="@+id/scanBtn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Сканировать QR"/>
    <TextView android:id="@+id/resultText" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textColor="#00e5a0" android:textSize="16sp"
        android:padding="16dp" android:layout_marginTop="20dp" android:textIsSelectable="true"
        android:background="#16161d" android:minHeight="80dp"/>
    <Button android:id="@+id/copyBtn" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Копировать"
        android:enabled="false" android:layout_marginTop="12dp"/>
</LinearLayout>
